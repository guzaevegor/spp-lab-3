<Window x:Class="DirectoryScannerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DirectoryScannerApp"
        Title="Directory Scanner" Height="600" Width="800">
    
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Выбрать папку и сканировать" 
                    Command="{Binding StartScanCommand}" 
                    Width="200" Height="30" Margin="0,0,10,0"/>
            
            <Button Content="Отмена" 
                    Command="{Binding CancelCommand}" 
                    Width="100" Height="30"/>
            
            <TextBlock Text="Сканирование в процессе..." 
                       VerticalAlignment="Center" Margin="15,0,0,0"
                       Foreground="Blue"
                       Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>

        <!-- TreeView с иерархическим шаблоном [web:1][web:5] -->
        <TreeView Grid.Row="1" ItemsSource="{Binding ScannedData}">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type local:DirectoryNodeViewModel}" ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="{Binding IconPath}" />
                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                        <TextBlock Text=" (" Foreground="Gray"/>
                        <TextBlock Text="{Binding DisplaySize}" Foreground="Gray"/>
                        <TextBlock Text=", " Foreground="Gray"/>
                        <TextBlock Text="{Binding Percent}" Foreground="Gray"/>
                        <TextBlock Text=")" Foreground="Gray"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</Window>
